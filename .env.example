VITE_FIREBASE_API_KEY="AIzaSyB6m8TdD5BeygUOXfW4D5tqzBz6W36tzZc"
VITE_FIREBASE_AUTH_DOMAIN="my-bill-generator-1924f.firebaseapp.com"
